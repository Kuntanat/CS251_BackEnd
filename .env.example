# ==========================================
#  CS251_BackEnd — Environment Variables
# ==========================================
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงลงไป
# cp .env.example .env
# ==========================================

# ----- Server -----
SERVER_PORT=8080

# ----- Database (MySQL) -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cs251_db
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here
DB_POOL_SIZE=10

# ----- JPA -----
# update | create | create-drop | validate | none
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ----- JWT -----
# ต้องมีความยาวอย่างน้อย 32 ตัวอักษร (256 bits)
JWT_SECRET=change-this-to-a-very-long-random-secret-key-min-32-chars
JWT_EXPIRATION=86400000         # 24 ชั่วโมง (ms)
JWT_REFRESH_EXPIRATION=604800000  # 7 วัน (ms)

# ----- Logging -----
LOG_LEVEL=INFO
LOG_LEVEL_SECURITY=WARN
